# Copy to geoshift.env and fill in. Keep geoshift.env out of git (see .gitignore).
# Linux: SSH key must be mode 600: chmod 600 /path/to/your.pem
# Linux (systemd): path is often repo root ./geoshift.env symlinked from /etc/geoshift/geoshift.env
#
# Windows + Task Scheduler (runs ssh as LOCAL SYSTEM):
# OpenSSH checks BOTH ACL permissions AND file ownership. If the owner is not
# NT AUTHORITY\SYSTEM (e.g. BUILTIN\Administrators from when you first copied
# the file), SSH refuses the key with "bad permissions" and the server returns
# "Permission denied (publickey)" - even if SYSTEM:(R) appears in icacls output.
#
# Fix (run as Administrator after copying the .pem):
#   $acl = Get-Acl "C:\ProgramData\GeoShift\ssh-keys\lightsail.pem"
#   $acl.SetOwner([System.Security.Principal.NTAccount]"NT AUTHORITY\SYSTEM")
#   Set-Acl "C:\ProgramData\GeoShift\ssh-keys\lightsail.pem" $acl
#   icacls "C:\ProgramData\GeoShift\ssh-keys\lightsail.pem" /inheritance:r /grant:r "NT AUTHORITY\SYSTEM:(R)"
#
# Easier: re-run install.ps1 after setting SSH_PRIVATE_KEY - it calls
# Set-SshKeyPermissionsForSystem automatically.
#
# For manual ssh as your user, keep a separate copy under C:\Users\you\.ssh\
# 
# macOS (install-macos.sh): ~/.config/geoshift/geoshift.env (LaunchAgent + root LaunchDaemon read this)

# --- US tunnel (SOCKS5 :1080) ---
US_LIGHTSAIL_IP=your.us.lightsail.ipv4

# Linux:
#   SSH_PRIVATE_KEY=~/.ssh/LightsailDefaultKey-us-east-2.pem
# Windows (GeoShift scheduled task runs as SYSTEM - key must be owned by SYSTEM):
#   SSH_PRIVATE_KEY=C:\ProgramData\GeoShift\ssh-keys\LightsailDefaultKey-us-east-2.pem
SSH_PRIVATE_KEY=~/.ssh/LightsailDefaultKey-us-east-2.pem

# Default is "ubuntu" for AWS Lightsail instances
SSH_USER=ubuntu

# --- JP tunnel (SOCKS5 :1081) ---
JP_LIGHTSAIL_IP=your.jp.lightsail.ipv4

# Linux:
#   JP_SSH_PRIVATE_KEY=~/.ssh/LightsailDefaultKey-ap-northeast-1.pem
# Windows (GeoShift scheduled task runs as SYSTEM - key must be owned by SYSTEM):
#   JP_SSH_PRIVATE_KEY=C:\ProgramData\GeoShift\ssh-keys\LightsailDefaultKey-ap-northeast-1.pem
JP_SSH_PRIVATE_KEY=~/.ssh/LightsailDefaultKey-ap-northeast-1.pem

# --- Mihomo config ---
# Logical service names (documentation only - domains are in config/rules/us-ai.yaml).
# Extend that file when a tool hits a new hostname (see Mihomo connection log / dashboard).
SERVICE_LIST=claude,claude-web,anthropic-api,anthropic-cli,chatgpt-web,openai-api,openai-cli,gemini-api,gemini-cli,antigravity-api,antigravity-cli,gemini-code-assist,notebooklm-web


# Directory containing config.yaml
# Linux example:
#   GEOSHIFT_CONFIG_DIR=/home/you/Documents/gitproj/geoshift/config
# Windows example (install.ps1 copies config here by default):
#   GEOSHIFT_CONFIG_DIR=C:\ProgramData\GeoShift\config
# Directory containing config.yaml (required by mihomo-run.sh / tunnel helpers)
GEOSHIFT_CONFIG_DIR=/home/you/Documents/gitproj/geoshift/config
# macOS example: GEOSHIFT_CONFIG_DIR=/Users/you/projects/geoshift/config
