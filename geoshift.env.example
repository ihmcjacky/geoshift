# Copy to geoshift.env and fill in. Keep geoshift.env out of git (see .gitignore).
# Linux:   chmod 600 /path/to/your.pem
# Windows: icacls "C:\Users\you\.ssh\lightsail.pem" /grant "SYSTEM:(R)"

US_LIGHTSAIL_IP=your.us.lightsail.ipv4

# Linux path example:
#   SSH_PRIVATE_KEY=/home/you/.ssh/lightsail.pem
# Windows path example:
#   SSH_PRIVATE_KEY=C:\Users\you\.ssh\lightsail.pem
SSH_PRIVATE_KEY=/home/you/.ssh/lightsail.pem

# Default is "ubuntu" for AWS Lightsail instances
SSH_USER=ubuntu

# Logical service names (documentation only — domains are in config/rules/us-ai.yaml).
# Extend that file when a tool hits a new hostname (see Mihomo connection log / dashboard).
SERVICE_LIST=claude,claude-web,anthropic-api,anthropic-cli,chatgpt-web,openai-api,openai-cli,gemini-api,gemini-cli,antigravity-api,antigravity-cli,gemini-code-assist,notebooklm-web

# Directory containing config.yaml
# Linux example:
#   GEOSHIFT_CONFIG_DIR=/home/you/Documents/gitproj/geoshift/config
# Windows example (install.ps1 copies config here by default):
#   GEOSHIFT_CONFIG_DIR=C:\ProgramData\GeoShift\config
GEOSHIFT_CONFIG_DIR=/home/you/Documents/gitproj/geoshift/config
