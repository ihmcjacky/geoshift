# Copy to geoshift.env and fill in. Keep geoshift.env out of git (see .gitignore).
# Linux:   chmod 600 /path/to/your.pem
#
# Windows + Task Scheduler (runs ssh as LOCAL SYSTEM):
# OpenSSH checks BOTH ACL permissions AND file ownership. If the owner is not
# NT AUTHORITY\SYSTEM (e.g. BUILTIN\Administrators from when you first copied
# the file), SSH refuses the key with "bad permissions" and the server returns
# "Permission denied (publickey)" - even if SYSTEM:(R) appears in icacls output.
#
# Fix (run as Administrator after copying the .pem):
#   $acl = Get-Acl "C:\ProgramData\GeoShift\ssh-keys\us-key.pem"
#   $acl.SetOwner([System.Security.Principal.NTAccount]"NT AUTHORITY\SYSTEM")
#   Set-Acl "C:\ProgramData\GeoShift\ssh-keys\us-key.pem" $acl
#   icacls "C:\ProgramData\GeoShift\ssh-keys\us-key.pem" /inheritance:r /grant:r "NT AUTHORITY\SYSTEM:(R)"
#
# Easier: re-run install.ps1 after setting US_SSH_KEY/JP_SSH_KEY - it calls
# Set-SshKeyPermissionsForSystem automatically.
#
# For manual ssh as your user, keep a separate copy under C:\Users\you\.ssh\

# --- US tunnel (SOCKS5 :1080) ---
US_HOST=your.us.exit.ipv4

# Linux:
#   US_SSH_KEY=~/.ssh/us-key.pem
# Windows (GeoShift scheduled task runs as SYSTEM - key must be owned by SYSTEM):
#   US_SSH_KEY=C:\ProgramData\GeoShift\ssh-keys\us-key.pem
US_SSH_KEY=~/.ssh/us-key.pem

# Default is "ubuntu" for standard cloud instances
SSH_USER=ubuntu

# --- JP tunnel (SOCKS5 :1081) ---
JP_HOST=your.jp.exit.ipv4

# Linux:
#   JP_SSH_KEY=~/.ssh/jp-key.pem
# Windows (GeoShift scheduled task runs as SYSTEM - key must be owned by SYSTEM):
#   JP_SSH_KEY=C:\ProgramData\GeoShift\ssh-keys\jp-key.pem
JP_SSH_KEY=~/.ssh/jp-key.pem

# --- NordVPN HTTPS proxy (JP-STRICT / Abema) ---
# Service credentials only (NOT your nordaccount.com login password).
# Nord Account -> NordVPN -> Set up manually -> Service credentials.
# After copying this file to geoshift.env, set both values, then re-run install.ps1
# or edit C:\ProgramData\GeoShift\config\config.yaml and run: geoshift reload
NORDVPN_SERVICE_USERNAME=your-service-username
NORDVPN_SERVICE_PASSWORD=your-service-password

# --- Mihomo config ---
# Logical service names (documentation only - domains are in config/rules/us-ai.yaml).
# Extend that file when a tool hits a new hostname (see Mihomo connection log / dashboard).
SERVICE_LIST=claude,claude-web,anthropic-api,anthropic-cli,chatgpt-web,openai-api,openai-cli,gemini-api,gemini-cli,antigravity-api,antigravity-cli,gemini-code-assist,notebooklm-web

# Directory containing config.yaml (set automatically by install.sh / install.ps1)
# Linux (install.sh deploys config here):
#   GEOSHIFT_CONFIG_DIR=/etc/geoshift/config
# Windows (install.ps1 copies config here):
#   GEOSHIFT_CONFIG_DIR=C:\ProgramData\GeoShift\config
GEOSHIFT_CONFIG_DIR=/etc/geoshift/config
